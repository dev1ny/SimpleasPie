{
  "productName": "商超利润计算器",
  "version": "0.1.0",
  "identifier": "com.supermarket.calculator",
  "build": {
    "frontendDist": "../frontend",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "node ./scripts/dev-frontend.mjs",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "商超利润计算器",
        "width": 900,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 400,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
